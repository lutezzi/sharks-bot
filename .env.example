# Discord Developer Portal (https://discord.com/developers/applications) uzerinden alinir.
DISCORD_TOKEN=BOT_TOKENINIZ
CLIENT_ID=UYGULAMA_CLIENT_ID
GUILD_ID=TEST_SUNUCU_ID

# Slash komutlarini sadece tek bir sunucuya (GUILD_ID) mi yoksa
# tum sunuculara mi (global) kaydetmek istediginizi belirler.
# Gelistirme sirasinda "guild", yayinda "global" onerilir.
DEPLOY_MODE=guild

# Botun kullanacagi dil dosyasi (src/locales/<KOD>.json). Yeni bir dil
# eklemek icin o klasore <kod>.json dosyasi olusturup burada belirtin.
LOCALE=en
